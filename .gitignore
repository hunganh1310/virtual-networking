# ============================================================================
# Virtual Networking Lab — .gitignore
# ============================================================================

# ---------------------------------------------------------------------------
# VM Images (large binaries)
# ---------------------------------------------------------------------------
*.qcow2
*.qcow2.bak
*.raw
*.iso
*.img

# ---------------------------------------------------------------------------
# Boot files (extracted from images)
# ---------------------------------------------------------------------------
boot/vmlinuz
boot/initrd
legacy/task1-qemu-kvm/boot/

# ---------------------------------------------------------------------------
# Runtime files
# ---------------------------------------------------------------------------
*.pid
*.log
*.sock

# ---------------------------------------------------------------------------
# Benchmark results (keep structure, ignore large data)
# results/ is tracked but individual run dirs may be large
# ---------------------------------------------------------------------------
results/*/2*-*/           # Timestamped run directories
results/comparison/2*-*   # Timestamped comparison reports

# ---------------------------------------------------------------------------
# OS / Editor
# ---------------------------------------------------------------------------
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
linux-*/
*.tar.xz
*.tar.gz
*.tar.bz2
*.rpm
rpmbuild/
repodata/

# ---------------------------------------------------------------------------
# Legacy images and data
# ---------------------------------------------------------------------------
legacy/task1-qemu-kvm/images/
legacy/task3-vpp/images/
legacy/task3-vpp/*.qcow2
legacy/task3-vpp/*.log
legacy/task3-vpp/*.pid
